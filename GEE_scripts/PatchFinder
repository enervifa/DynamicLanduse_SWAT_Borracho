function extractPolygonMean(ic, polys, varName){
  return ic.map(function(img){
    var proj = img.projection();
    var date = ee.Date(img.get('system:time_start')).format('YYYY-MM-dd');

    return img.reduceRegions({
      collection: polys,
      reducer: ee.Reducer.mean(),
      crs: proj,
      scale: proj.nominalScale(),
      tileScale: 8
    }).map(function(f){
      return f.set({
        date: date,
        variable: varName,
        value: f.get('mean')
      });
    });
  }).flatten();
}

