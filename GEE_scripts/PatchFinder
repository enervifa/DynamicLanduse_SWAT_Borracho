var patch_centroids = patches_id.map(function(f){
  return ee.Feature(
    f.geometry().centroid(1),
    f.toDictionary()
  );
});

function extractCentroidTS(ic, centroids, bandName, varName){
  return ic.map(function(img){
    var proj = img.projection();
    var date = ee.Date(img.get('system:time_start')).format('YYYY-MM-dd');

    return centroids.map(function(c){
      var v = img.reduceRegion({
        reducer: ee.Reducer.mean(),
        geometry: c.geometry(),
        crs: proj,
        scale: proj.nominalScale(),
        maxPixels: 1e7
      }).get(bandName);

      return ee.Feature(null, {
        patch_id: c.get('patch_id'),
        date: date,
        variable: varName,
        value: v
      });
    });
  }).flatten();
}

var laiCentTS = extractCentroidTS(laiCol, patch_centroids, 'LAI', 'LAI');
var etCentTS  = extractCentroidTS(etCol,  patch_centroids, 'ET',  'ET');

var tsCentroid = laiCentTS.merge(etCentTS);

